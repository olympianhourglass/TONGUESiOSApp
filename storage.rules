rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // TTS / pronunciation audio cache. Files are SHA-256-hashed, so unknown
    // phrases are effectively unenumerable; safe to read anonymously.
    // Writes still require auth so the bucket can't be filled by a hostile
    // anonymous client.
    match /audio-cache/{filename} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
