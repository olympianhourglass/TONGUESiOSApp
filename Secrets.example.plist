<?xml version="1.0" encoding="UTF-8"?>
<!--
  Template for the app's API keys.

  Setup:
    1. Copy this file to `Secrets.plist` (same folder).
    2. Fill in your own keys below.
    3. `Secrets.plist` is gitignored, so your keys stay out of the repo.

  See Services/Secrets.swift for how these are read at runtime.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ANTHROPIC_API_KEY</key>
	<string></string>
	<key>ELEVENLABS_API_KEY</key>
	<string></string>
	<key>FORVO_API_KEY</key>
	<string></string>
	<key>SUPADATA_API_KEY</key>
	<string></string>
</dict>
</plist>
